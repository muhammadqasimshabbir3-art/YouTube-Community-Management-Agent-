# LLM
GROQ_API_KEY=gsk_your_key_here

# Login credentials (account used to browse and post replies — 2FA must be disabled)
YOUTUBE_EMAIL=your.email@gmail.com
YOUTUBE_PASSWORD=your_password_here

# Target channel to analyze (any channel — not necessarily the login account)
# Provide a name OR a URL. Name is searched on YouTube; latest video is analyzed.
YOUTUBE_CHANNEL_NAME=MrBeast
YOUTUBE_CHANNEL_URL=

# Browser automation
BROWSER_HEADLESS=true
BROWSER_LOGIN_TIMEOUT_MS=45000
YOUTUBE_SESSION_PATH=./data/youtube_session.json
REPLY_HISTORY_PATH=./data/reply_history.json
MAX_VIDEOS_TO_SCAN=1
# 0 = scrape and analyze all visible comments on the video
MAX_COMMENTS_PER_VIDEO=0
# Only the top N positive comments receive replies after full analysis
MAX_REPLIES_PER_VIDEO=5
REPLY_PERSONALITY=humorous

# Reply behavior
ENABLE_COMMENT_REPLIES=false
ENABLE_NEW_COMMENTS=false
NEW_COMMENT_TEXT=
MAX_NEW_COMMENTS=1
# Keep Chrome open from scrape through reply/comment posting; closed before HTML report.
KEEP_BROWSER_OPEN=true
PLAYWRIGHT_BROWSERS_PATH=
REPLY_TO_POSITIVE=true
REPLY_TO_NEGATIVE=false
REPLY_TO_NEUTRAL=false
REPLY_TO_QUESTIONS=true
REPLY_TO_SUGGESTIONS=true
REPLY_TO_SPAM=false

# Email (HTML dashboard + PDF attached when enabled)
EMAIL_REPORTS=true
GMAIL_SMTP_USER=your.email@gmail.com
GMAIL_APP_PASSWORD="abcd efgh ijkl mnop"
GMAIL_DEFAULT_RECIPIENT=your.email@gmail.com

# Optional tracing
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=youtube-community-manager

# Service ports (local dev)
LANGGRAPH_PORT=2024
FRONTEND_PORT=5173
STREAMLIT_PORT=8501

# Frontend ↔ LangGraph connection (read by Vite from this root .env)
# Local direct URL (CORS enabled in langgraph.json):
VITE_LANGGRAPH_API_URL=http://127.0.0.1:2024
VITE_LANGGRAPH_ASSISTANT_ID=agent
VITE_UI_URL=http://localhost:5173
# Optional UI defaults (pre-fill channel form; mirror backend .env values)
VITE_DEFAULT_CHANNEL_NAME=
VITE_DEFAULT_CHANNEL_URL=
VITE_DEFAULT_MAX_VIDEOS_TO_SCAN=1
VITE_DEFAULT_MAX_COMMENTS_PER_VIDEO=0
VITE_DEFAULT_MAX_REPLIES=5
VITE_DEFAULT_REPLY_PERSONALITY=humorous
VITE_DEFAULT_ENABLE_COMMENT_REPLIES=true
VITE_DEFAULT_ENABLE_NEW_COMMENTS=false
VITE_DEFAULT_NEW_COMMENT_TEXT=
VITE_DEFAULT_MAX_NEW_COMMENTS=1
VITE_DEFAULT_KEEP_BROWSER_OPEN=true
VITE_DEFAULT_REPLY_TO_POSITIVE=true
VITE_DEFAULT_REPLY_TO_NEGATIVE=false
VITE_DEFAULT_REPLY_TO_NEUTRAL=false
VITE_DEFAULT_REPLY_TO_QUESTIONS=true
VITE_DEFAULT_REPLY_TO_SUGGESTIONS=true
VITE_DEFAULT_REPLY_TO_SPAM=false
VITE_DEFAULT_EMAIL_REPORTS=true
VITE_DEFAULT_EMAIL_RECIPIENT=
# Production: set VITE_LANGGRAPH_API_URL=https://your-langgraph-server.example.com
